{
  "name": "@buildpad/ui-files",
  "version": "1.6.0",
  "description": "Files management UI (manager + detail) for Buildpad projects",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts --external react --external @mantine/core --external @mantine/hooks --external @mantine/notifications --external @tabler/icons-react",
    "dev": "tsup src/index.ts --format esm,cjs --dts --watch",
    "clean": "rimraf dist",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests",
    "storybook": "storybook dev -p 6009",
    "build-storybook": "storybook build"
  },
  "peerDependencies": {
    "@mantine/core": "^8.0.0",
    "@mantine/hooks": "^8.0.0",
    "@mantine/notifications": "^8.0.0",
    "@buildpad/hooks": "workspace:*",
    "@buildpad/services": "workspace:*",
    "@buildpad/types": "workspace:*",
    "@buildpad/ui-interfaces": "workspace:*",
    "@tabler/icons-react": "^3.0.0",
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0"
  },
  "devDependencies": {
    "@mantine/core": "^8.0.0",
    "@mantine/hooks": "^8.0.0",
    "@mantine/notifications": "^8.0.0",
    "@buildpad/hooks": "workspace:*",
    "@buildpad/services": "workspace:*",
    "@buildpad/types": "workspace:*",
    "@buildpad/ui-interfaces": "workspace:*",
    "@storybook/addon-a11y": "^10.2.8",
    "@storybook/addon-docs": "^10.2.8",
    "@storybook/addon-links": "^10.2.8",
    "@storybook/nextjs-vite": "^10.2.8",
    "@storybook/react": "^10.2.8",
    "@tabler/icons-react": "^3.0.0",
    "@types/react": "^19.1.6",
    "@types/react-dom": "^19.1.5",
    "next": "^16.0.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "rimraf": "^6.0.0",
    "storybook": "^10.2.8",
    "tsup": "^8.4.0",
    "typescript": "^5.8.3",
    "vite": "^6.0.0",
    "vitest": "^2.0.0"
  },
  "private": true,
  "keywords": [
    "buildpad",
    "files",
    "file-manager",
    "media",
    "daas",
    "mantine",
    "react"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/microbuild-ui/ui"
  }
}
