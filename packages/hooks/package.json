{
  "name": "@buildpad/hooks",
  "version": "1.9.3",
  "private": true,
  "description": "Shared React hooks for Buildpad projects - DaaS-compatible relation hooks",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./package.json": "./package.json"
  },
  "sideEffects": false,
  "scripts": {
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@buildpad/types": "workspace:*",
    "@buildpad/services": "workspace:*",
    "@buildpad/utils": "workspace:*"
  },
  "peerDependencies": {
    "@mantine/notifications": "^8.0.0",
    "react": "^18.0.0 || ^19.0.0"
  },
  "devDependencies": {
    "@mantine/notifications": "^8.3.9",
    "@testing-library/react": "^16.3.0",
    "@types/node": "^22",
    "@types/react": "^19",
    "jsdom": "^25.0.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "typescript": "^5.9.3",
    "vitest": "^2.0.0"
  }
}
