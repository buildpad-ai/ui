{
  "name": "@buildpad/ui-forms",
  "version": "1.9.2",
  "description": "Dynamic form builder (design-time authoring + runtime renderer) for Buildpad projects",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts --external react --external @mantine/core --external @mantine/hooks --external @mantine/notifications --external @tabler/icons-react --external @dnd-kit/core --external @dnd-kit/sortable --external @dnd-kit/utilities",
    "dev": "tsup src/index.ts --format esm,cjs --dts --watch",
    "clean": "rimraf dist",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests",
    "test:e2e": "tsx scripts/e2e-daas.mts",
    "storybook": "storybook dev -p 6010",
    "build-storybook": "storybook build"
  },
